---
interface Props {
  locale: string;
  greenMenu?: boolean;
}

const { locale, greenMenu = false } = Astro.props;

const navLinks = [
  { label: 'Building',      href: `/${locale}/Building` },
  { label: 'Accommodation', href: `/${locale}/Accommodation` },
  { label: 'Services',      href: `/${locale}/Services` },
  { label: 'Location',      href: `/${locale}/Location` },
  { label: 'Contact',       href: '#contact' },
];

const langLinks = [
  { label: 'EN', href: `/en/Terms?home`, active: locale === 'en' },
  { label: 'FR', href: `/fr/Terms?home`, active: locale === 'fr' },
  { label: 'NL', href: `/nl/Terms?home`, active: locale === 'nl' },
];

const leftLinks  = navLinks.slice(0, 3);
const rightLinks = navLinks.slice(3);
---

<!-- Mobile slide-down menu (outside .container) -->
<nav class="menu menu__mobile">
  <a href="#" class="menu__link-close icon icon--close"></a>
  <div class="menu__mobile-text">MENU</div>
  <div class="menu__mobile-content">
    {navLinks.map(link => (
      <a href={link.href} class="menu__link">{link.label}</a>
    ))}
  </div>
  <div class="menu__mobile-lang">
    {langLinks.map(link => (
      <a href={link.href} class:list={['menu__link', 'menu__link--lang', { 'menu__link--active': link.active }]}>
        {link.label}
      </a>
    ))}
  </div>
</nav>

<!-- Desktop header (inside .container, rendered by BaseLayout) -->
<header class="header" id="header">
