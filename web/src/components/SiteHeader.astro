          <a href={`/${locale}/Terms`}>More information</a>
        </div>
        <a class="warnning__btn" id="warning-close">
          <span class="warnning__btn-text">Accept and close</span>
          <span class="icon icon--close"></span>
        </a>
      </div>
    </div> -->

